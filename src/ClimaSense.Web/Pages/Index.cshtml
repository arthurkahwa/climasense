@page
@model ClimaSense.Web.Pages.IndexModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClimaSense — dashboard</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
            background: #0d1117;
            color: #c9d1d9;
            margin: 0;
            padding: 2rem;
            line-height: 1.5;
        }
        h1 {
            color: #58a6ff;
            font-weight: 500;
            margin-top: 0;
        }
        code, pre {
            background: #161b22;
            border-radius: 6px;
            padding: 0.15rem 0.4rem;
            color: #d2a8ff;
        }
        pre {
            padding: 1rem;
            overflow-x: auto;
        }
        .panel {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 8px;
            padding: 1rem 1.25rem;
            margin: 1rem 0;
        }
        /* Slice 3: latest-reading card */
        .latest-card {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            align-items: center;
            background: linear-gradient(145deg, #161b22, #0d1117);
            border: 1px solid #30363d;
            border-radius: 12px;
            padding: 1.5rem 2rem;
            margin: 1rem 0 2rem 0;
        }
        .latest-card .reading {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
        }
        .latest-card .label {
            color: #8b949e;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }
        .latest-card .value {
            font-size: 3rem;
            font-weight: 600;
            color: #f0f6fc;
            line-height: 1;
        }
        .latest-card .value .unit {
            font-size: 1.5rem;
            font-weight: 400;
            color: #8b949e;
            margin-left: 0.25rem;
        }
        .latest-card .meta {
            grid-column: 1 / -1;
            color: #8b949e;
            font-size: 0.85rem;
            border-top: 1px solid #30363d;
            padding-top: 0.75rem;
        }
        .latest-card.error .value {
            color: #f85149;
            font-size: 1.5rem;
            font-weight: 500;
        }
        .heartbeat-counter {
            font-size: 2rem;
            font-weight: 600;
            color: #56d364;
        }
        .heartbeat-meta {
            color: #8b949e;
            font-size: 0.9rem;
        }
        ul.legend {
            color: #8b949e;
            font-size: 0.9rem;
        }
        /* Slice 7: comfort card */
        .comfort-card {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 1.5rem;
            align-items: center;
            background: linear-gradient(145deg, #161b22, #0d1117);
            border: 1px solid #30363d;
            border-radius: 12px;
            padding: 1.25rem 1.75rem;
            margin: 1rem 0 2rem 0;
        }
        .comfort-card .field {
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
        }
        .comfort-card .label {
            color: #8b949e;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }
        .comfort-card .value {
            font-size: 2.25rem;
            font-weight: 600;
            color: #f0f6fc;
            line-height: 1;
        }
        .comfort-card .value .unit {
            font-size: 1.25rem;
            font-weight: 400;
            color: #8b949e;
            margin-left: 0.25rem;
        }
        .comfort-card .meta {
            grid-column: 1 / -1;
            color: #8b949e;
            font-size: 0.85rem;
            border-top: 1px solid #30363d;
            padding-top: 0.75rem;
        }
        .comfort-card.error .value {
            color: #f85149;
            font-size: 1.25rem;
            font-weight: 500;
        }
        .rating-excellent { color: #56d364; }
        .rating-acceptable { color: #79c0ff; }
        .rating-marginal { color: #d29922; }
        .rating-uncomfortable { color: #f85149; }
        /* Slice 8: anomaly card */
        .anomaly-card {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 1.5rem;
            align-items: center;
            background: linear-gradient(145deg, #161b22, #0d1117);
            border: 1px solid #30363d;
            border-radius: 12px;
            padding: 1.25rem 1.75rem;
            margin: 1rem 0 2rem 0;
        }
        .anomaly-card .field {
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
        }
        .anomaly-card .label {
            color: #8b949e;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }
        .anomaly-card .value {
            font-size: 1.5rem;
            font-weight: 600;
            color: #f0f6fc;
            line-height: 1;
        }
        .anomaly-card .meta {
            grid-column: 1 / -1;
            color: #8b949e;
            font-size: 0.85rem;
            border-top: 1px solid #30363d;
            padding-top: 0.75rem;
        }
        .anomaly-card.error .value,
        .anomaly-card.empty .value {
            color: #8b949e;
            font-size: 1.25rem;
            font-weight: 500;
        }
        .anomaly-pill {
            display: inline-block;
            padding: 0.2rem 0.6rem;
            border-radius: 999px;
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: lowercase;
            letter-spacing: 0.02em;
        }
        .anomaly-pill.sensor_failure {
            background: rgba(248, 81, 73, 0.15);
            color: #f85149;
            border: 1px solid rgba(248, 81, 73, 0.35);
        }
        .anomaly-pill.regime_shift {
            background: rgba(210, 153, 34, 0.15);
            color: #d29922;
            border: 1px solid rgba(210, 153, 34, 0.35);
        }
        .anomaly-pill.residual_outlier {
            background: rgba(121, 192, 255, 0.15);
            color: #79c0ff;
            border: 1px solid rgba(121, 192, 255, 0.35);
        }
        /* Slice 10: comfort budget panel */
        .budget-card {
            display: grid;
            grid-template-columns: 1fr 1fr 2fr;
            gap: 1.5rem;
            align-items: stretch;
            background: linear-gradient(145deg, #161b22, #0d1117);
            border: 1px solid #30363d;
            border-radius: 12px;
            padding: 1.25rem 1.75rem;
            margin: 1rem 0 2rem 0;
        }
        .budget-card .subcard {
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 0.5rem;
        }
        .budget-card .label {
            color: #8b949e;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }
        .budget-card .big-number {
            font-size: 3rem;
            font-weight: 600;
            color: #f0f6fc;
            line-height: 1;
        }
        .budget-card .big-number .unit {
            font-size: 1.25rem;
            font-weight: 400;
            color: #8b949e;
            margin-left: 0.25rem;
        }
        .budget-card .big-number.discomfort-high { color: #f85149; }
        .budget-card .big-number.discomfort-medium { color: #d29922; }
        .budget-card .big-number.discomfort-low { color: #56d364; }
        .budget-card .worst-line {
            font-size: 1.1rem;
            color: #f0f6fc;
            font-weight: 500;
        }
        .budget-card .worst-z {
            color: #8b949e;
            font-size: 0.9rem;
        }
        .budget-card .pattern-pill {
            display: inline-block;
            padding: 0.18rem 0.55rem;
            border-radius: 999px;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: lowercase;
            letter-spacing: 0.02em;
        }
        .budget-card .pattern-pill.quiet {
            background: rgba(139, 148, 158, 0.15);
            color: #8b949e;
            border: 1px solid rgba(139, 148, 158, 0.35);
        }
        .budget-card .pattern-pill.warm {
            background: rgba(248, 81, 73, 0.15);
            color: #f85149;
            border: 1px solid rgba(248, 81, 73, 0.35);
        }
        .budget-card .pattern-pill.cool {
            background: rgba(121, 192, 255, 0.15);
            color: #79c0ff;
            border: 1px solid rgba(121, 192, 255, 0.35);
        }
        .budget-card .pattern-pill.volatile {
            background: rgba(210, 153, 34, 0.15);
            color: #d29922;
            border: 1px solid rgba(210, 153, 34, 0.35);
        }
        .budget-card .trend-svg {
            width: 100%;
            height: 60px;
            display: block;
        }
        .budget-card .trend-empty {
            color: #8b949e;
            font-size: 0.9rem;
        }
        .budget-card .meta {
            grid-column: 1 / -1;
            color: #8b949e;
            font-size: 0.85rem;
            border-top: 1px solid #30363d;
            padding-top: 0.75rem;
            margin-top: 0.25rem;
        }
        .budget-card.error .big-number,
        .budget-card.error .worst-line {
            color: #f85149;
            font-size: 1.25rem;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <h1>ClimaSense — dashboard</h1>

    <nav style="color:#8b949e;font-size:0.9rem;margin-bottom:0.5rem;">
        Dashboard ·
        <a href="/Explorer" style="color:#58a6ff;">Historical Explorer</a> ·
        <a href="/Analysis" style="color:#58a6ff;">Model Leaderboard</a>
    </nav>

    <p>
        Live read: the latest <code>SensorReadings</code> row served by
        the .NET tier directly from SQL (no ml-tier hop). The
        heartbeat counter below remains as the SSE plumbing smoke test
        from slice 1; later slices replace this whole page with the
        proper dashboard. Slice 4 adds the
        <a href="/Explorer" style="color:#58a6ff;">Historical Explorer</a>
        for range + heatmap exploration.
    </p>

    <!-- ============================================== -->
    <!-- Slice 3: latest-reading card                  -->
    <!-- ============================================== -->
    <section class="latest-card" id="latest-card">
        <div class="reading">
            <span class="label">Temperature</span>
            <span class="value">
                <span id="latest-temp">&hellip;</span><span class="unit">&deg;C</span>
            </span>
        </div>
        <div class="reading">
            <span class="label">Humidity</span>
            <span class="value">
                <span id="latest-humidity">&hellip;</span><span class="unit">%</span>
            </span>
        </div>
        <div class="meta" id="latest-meta">
            Fetching latest reading from
            <code>/api/readings/latest</code>&hellip;
        </div>
    </section>

    <!-- ============================================== -->
    <!-- Slice 8: last anomaly card                    -->
    <!-- ============================================== -->
    <section class="anomaly-card" id="anomaly-card">
        <div class="field">
            <span class="label">Last anomaly</span>
            <span class="value" id="anomaly-type-wrap">
                <span id="anomaly-type">&hellip;</span>
            </span>
        </div>
        <div class="field">
            <span class="label">Severity</span>
            <span class="value">
                <span id="anomaly-severity">&hellip;</span>
            </span>
        </div>
        <div class="field">
            <span class="label">Detected</span>
            <span class="value" id="anomaly-detected">&hellip;</span>
        </div>
        <div class="meta" id="anomaly-meta">
            Fetching latest anomaly from
            <code>/api/anomalies/latest</code>&hellip;
        </div>
    </section>

    <!-- ============================================== -->
    <!-- Slice 7: comfort score card                   -->
    <!-- ============================================== -->
    <section class="comfort-card" id="comfort-card">
        <div class="field">
            <span class="label">Comfort score</span>
            <span class="value">
                <span id="comfort-score">&hellip;</span><span class="unit">/100</span>
            </span>
        </div>
        <div class="field">
            <span class="label">Rating</span>
            <span class="value" id="comfort-rating-wrap">
                <span id="comfort-rating">&hellip;</span>
            </span>
        </div>
        <div class="field">
            <span class="label">Season</span>
            <span class="value">
                <span id="comfort-season">&hellip;</span>
            </span>
        </div>
        <div class="meta" id="comfort-meta">
            Fetching latest comfort score from
            <code>/api/comfort/current</code>&hellip;
        </div>
    </section>

    <!-- ============================================== -->
    <!-- Slice 10: Comfort Budget (7-day) panel        -->
    <!-- ============================================== -->
    <section class="panel">
        <strong>Comfort Budget (7-day)</strong>
        <div class="budget-card" id="budget-card" style="margin-top:0.75rem;">
            <div class="subcard">
                <span class="label">Hours outside zone</span>
                <span class="big-number" id="budget-hours-wrap">
                    <span id="budget-hours">&hellip;</span><span class="unit">h</span>
                </span>
                <span class="worst-z" id="budget-hours-sub">
                    last 7 days, score &lt; &hellip;
                </span>
            </div>
            <div class="subcard">
                <span class="label">Worst calendar cell</span>
                <span class="worst-line" id="budget-worst-line">&hellip;</span>
                <span class="worst-z" id="budget-worst-z">&hellip;</span>
            </div>
            <div class="subcard">
                <span class="label">7-day comfort trend (mean)</span>
                <svg class="trend-svg" id="budget-trend-svg"
                     viewBox="0 0 200 60" preserveAspectRatio="none"
                     aria-label="7-day comfort trend sparkline"></svg>
                <span class="trend-empty" id="budget-trend-empty"
                      style="display:none;">no trend yet</span>
            </div>
            <div class="meta" id="budget-meta">
                Fetching from <code>/api/comfort/budget</code>&hellip;
            </div>
        </div>
    </section>

    <section class="panel">
        <strong>Heartbeat (slice-1 SSE smoke test)</strong>
        <div class="heartbeat-counter" id="tick-count">0</div>
        <div class="heartbeat-meta">
            <span id="last-tick-ts">awaiting first heartbeat&hellip;</span>
            &nbsp;|&nbsp;
            <span id="conn-state">connecting&hellip;</span>
        </div>
    </section>

    <section class="panel">
        <strong>What slice 7 ships</strong>
        <ul class="legend">
            <li>Pure <code>ComfortCalculator</code> on the ml tier —
                ASHRAE 55-2020 graphical comfort zone with summer /
                winter polygons (per ADR-0005). Season is selected by
                calendar month + <code>COMFORT_HEMISPHERE</code> env
                var (default <code>N</code>).</li>
            <li>APScheduler β-prime gate (slice-5 pattern) — one
                <code>ComfortScores</code> row per replay-hour.</li>
            <li><code>GET /api/comfort/current</code> served by the
                .NET tier directly from
                <code>dbo.fv_comfortscores_at_cursor(@@asOf)</code>
                (read-path bypass per ADR-0010).</li>
            <li><code>POST /api/ml/run/comfort</code> proxies the
                .NET tier through to the ml-tier
                <code>GET /api/comfort/score?hours=24</code> for
                on-demand recompute (idempotent on the cursor's
                bucket).</li>
        </ul>
    </section>

    <section class="panel">
        <strong>What slice 8 ships</strong>
        <ul class="legend">
            <li>Three concrete anomaly detectors on the ml tier (per
                ADR-0002 + ADR-0011: no <code>IAnomalyStrategy</code>
                seam): <code>SensorFailureRules</code> (SQL window
                functions, 24h scan, gap/stuck/range),
                <code>ResidualOutlierDetector</code> (consumes the
                boot-fitted <code>LagLinearForecaster</code>), and
                <code>ChangepointDetector</code> (PELT via
                <code>ruptures</code>, 90d scan-and-replace inside an
                <code>sp_getapplock</code>-guarded transaction).</li>
            <li>Per-type idempotency in the schema:
                <code>UNIQUE (AnomalyType, ReadingTime)</code> plus
                <code>INSERT … WHERE NOT EXISTS</code> for the
                point-in-time detectors; the changepoint detector
                scans-and-replaces deterministically.</li>
            <li>Nightly APScheduler <code>cron</code> job at 02:00 UTC
                runs all three detectors; <code>POST /api/ml/run/anomalies</code>
                triggers the same pipeline on demand.</li>
            <li><code>GET /api/anomalies/latest</code> +
                <code>GET /api/anomalies?start=&amp;end=&amp;type=</code>
                served by the .NET tier directly from
                <code>dbo.fv_anomalies_at_cursor(@@asOf)</code> —
                read-path bypass.</li>
        </ul>
    </section>

    <script>
        // ----------------------------------------------------------------
        // Slice 3: latest reading
        // ----------------------------------------------------------------
        (function () {
            var tempEl = document.getElementById('latest-temp');
            var humidityEl = document.getElementById('latest-humidity');
            var metaEl = document.getElementById('latest-meta');
            var cardEl = document.getElementById('latest-card');

            function formatTimestamp(iso) {
                try {
                    var d = new Date(iso);
                    return d.toLocaleString(undefined, {
                        year: 'numeric', month: 'short', day: '2-digit',
                        hour: '2-digit', minute: '2-digit',
                        timeZoneName: 'short',
                    });
                } catch (e) {
                    return iso;
                }
            }

            // textContent-only meta rendering. Avoids innerHTML so the
            // server-supplied readingTime can never inject markup even
            // if a future change starts shipping it from the wire as
            // a string we don't trust.
            function renderMeta(body) {
                while (metaEl.firstChild) {
                    metaEl.removeChild(metaEl.firstChild);
                }
                metaEl.appendChild(document.createTextNode('as of '));
                var ts = document.createElement('strong');
                ts.textContent = formatTimestamp(body.readingTime);
                metaEl.appendChild(ts);
                metaEl.appendChild(document.createTextNode(' · source: '));
                var code = document.createElement('code');
                code.textContent = 'SensorReadings';
                metaEl.appendChild(code);
                metaEl.appendChild(document.createTextNode(
                    ' (row with largest ReadingTime ≤ cursor)'));
            }

            function renderError(message) {
                cardEl.classList.add('error');
                // Replace temperature / humidity values with em-dashes.
                var tempParent = tempEl.parentElement;
                while (tempParent.firstChild) {
                    tempParent.removeChild(tempParent.firstChild);
                }
                tempParent.textContent = '—';
                var humParent = humidityEl.parentElement;
                while (humParent.firstChild) {
                    humParent.removeChild(humParent.firstChild);
                }
                humParent.textContent = '—';
                metaEl.textContent =
                    '/api/readings/latest failed: ' + message;
            }

            fetch('/api/readings/latest', { headers: { 'Accept': 'application/json' } })
                .then(function (resp) {
                    if (!resp.ok) {
                        return resp.json().then(function (body) {
                            throw {
                                status: resp.status,
                                error: body && body.error,
                                message: body && body.message
                            };
                        }, function () {
                            throw {
                                status: resp.status,
                                error: 'http_error',
                                message: 'HTTP ' + resp.status
                            };
                        });
                    }
                    return resp.json();
                })
                .then(function (body) {
                    tempEl.textContent = (body.temperatureC).toFixed(1);
                    humidityEl.textContent = (body.humidityPct).toFixed(1);
                    renderMeta(body);
                })
                .catch(function (err) {
                    renderError(err && err.message ? err.message : 'unknown error');
                });
        })();

        // ----------------------------------------------------------------
        // Slice 7: comfort score
        // ----------------------------------------------------------------
        (function () {
            var scoreEl = document.getElementById('comfort-score');
            var ratingEl = document.getElementById('comfort-rating');
            var ratingWrap = document.getElementById('comfort-rating-wrap');
            var seasonEl = document.getElementById('comfort-season');
            var metaEl = document.getElementById('comfort-meta');
            var cardEl = document.getElementById('comfort-card');

            function capitalize(s) {
                if (typeof s !== 'string' || s.length === 0) return s;
                return s.charAt(0).toUpperCase() + s.slice(1);
            }

            function formatTimestamp(iso) {
                try {
                    var d = new Date(iso);
                    return d.toLocaleString(undefined, {
                        year: 'numeric', month: 'short', day: '2-digit',
                        hour: '2-digit', minute: '2-digit',
                        timeZoneName: 'short',
                    });
                } catch (e) {
                    return iso;
                }
            }

            function renderMeta(body) {
                while (metaEl.firstChild) {
                    metaEl.removeChild(metaEl.firstChild);
                }
                metaEl.appendChild(document.createTextNode('bucket '));
                var ts = document.createElement('strong');
                ts.textContent = formatTimestamp(body.bucketTime);
                metaEl.appendChild(ts);
                metaEl.appendChild(document.createTextNode(' · source: '));
                var code = document.createElement('code');
                code.textContent = 'ComfortScores';
                metaEl.appendChild(code);
                metaEl.appendChild(document.createTextNode(
                    ' (latest row, cursor-clipped)'));
            }

            function renderError(message) {
                cardEl.classList.add('error');
                scoreEl.parentElement.textContent = '—';
                ratingEl.textContent = '—';
                seasonEl.textContent = '—';
                metaEl.textContent =
                    '/api/comfort/current: ' + message;
            }

            fetch('/api/comfort/current', { headers: { 'Accept': 'application/json' } })
                .then(function (resp) {
                    if (resp.status === 404) {
                        return resp.json().then(function (body) {
                            throw {
                                status: 404,
                                error: body && body.error,
                                message: (body && body.message) ||
                                    'no comfort row yet',
                            };
                        }, function () {
                            throw { status: 404, error: 'no_comfort_yet',
                                message: 'no comfort row yet' };
                        });
                    }
                    if (!resp.ok) {
                        return resp.json().then(function (body) {
                            throw {
                                status: resp.status,
                                error: body && body.error,
                                message: body && body.message
                            };
                        }, function () {
                            throw {
                                status: resp.status,
                                error: 'http_error',
                                message: 'HTTP ' + resp.status
                            };
                        });
                    }
                    return resp.json();
                })
                .then(function (body) {
                    // body: { score, rating, season, bucketTime, computedAt }
                    scoreEl.textContent = (body.score).toFixed(0);
                    ratingEl.textContent = capitalize(body.rating);
                    seasonEl.textContent = capitalize(body.season);
                    // Colour the rating wrapper by rating band.
                    ratingWrap.classList.add('rating-' + body.rating);
                    renderMeta(body);
                })
                .catch(function (err) {
                    renderError(err && err.message ? err.message : 'unknown error');
                });
        })();

        // ----------------------------------------------------------------
        // Slice 8: last anomaly
        // ----------------------------------------------------------------
        (function () {
            var typeEl = document.getElementById('anomaly-type');
            var typeWrap = document.getElementById('anomaly-type-wrap');
            var severityEl = document.getElementById('anomaly-severity');
            var detectedEl = document.getElementById('anomaly-detected');
            var metaEl = document.getElementById('anomaly-meta');
            var cardEl = document.getElementById('anomaly-card');

            var TYPE_LABEL = {
                sensor_failure: 'Sensor failure',
                regime_shift: 'Regime shift',
                residual_outlier: 'Residual outlier'
            };

            function formatTimestamp(iso) {
                try {
                    var d = new Date(iso);
                    return d.toLocaleString(undefined, {
                        year: 'numeric', month: 'short', day: '2-digit',
                        hour: '2-digit', minute: '2-digit',
                        timeZoneName: 'short',
                    });
                } catch (e) {
                    return iso;
                }
            }

            function renderMeta(body) {
                while (metaEl.firstChild) {
                    metaEl.removeChild(metaEl.firstChild);
                }
                metaEl.appendChild(document.createTextNode('reading at '));
                var ts = document.createElement('strong');
                ts.textContent = formatTimestamp(body.readingTime);
                metaEl.appendChild(ts);
                if (body.description) {
                    metaEl.appendChild(document.createTextNode(' · '));
                    metaEl.appendChild(document.createTextNode(body.description));
                }
                metaEl.appendChild(document.createTextNode(' · source: '));
                var code = document.createElement('code');
                code.textContent = 'Anomalies';
                metaEl.appendChild(code);
                metaEl.appendChild(document.createTextNode(
                    ' (latest row, cursor-clipped)'));
            }

            function renderEmpty(message) {
                cardEl.classList.add('empty');
                typeEl.textContent = 'none yet';
                severityEl.textContent = '—';
                detectedEl.textContent = '—';
                metaEl.textContent = message;
            }

            function renderError(message) {
                cardEl.classList.add('error');
                typeEl.textContent = '—';
                severityEl.textContent = '—';
                detectedEl.textContent = '—';
                metaEl.textContent =
                    '/api/anomalies/latest: ' + message;
            }

            fetch('/api/anomalies/latest', { headers: { 'Accept': 'application/json' } })
                .then(function (resp) {
                    if (resp.status === 404) {
                        return resp.json().then(function (body) {
                            renderEmpty((body && body.message) ||
                                'no anomalies have been detected yet');
                            return null;
                        }, function () {
                            renderEmpty('no anomalies have been detected yet');
                            return null;
                        });
                    }
                    if (!resp.ok) {
                        return resp.json().then(function (body) {
                            throw {
                                status: resp.status,
                                error: body && body.error,
                                message: body && body.message
                            };
                        }, function () {
                            throw {
                                status: resp.status,
                                error: 'http_error',
                                message: 'HTTP ' + resp.status
                            };
                        });
                    }
                    return resp.json();
                })
                .then(function (body) {
                    if (!body) return; // 404 path already rendered.
                    // body: { anomalyType, readingTime, severity, description, detectedAt }
                    // Render the type pill — colour comes from the class.
                    typeEl.classList.add('anomaly-pill', body.anomalyType);
                    typeEl.textContent = TYPE_LABEL[body.anomalyType] || body.anomalyType;
                    severityEl.textContent = (Number(body.severity)).toFixed(2);
                    detectedEl.textContent = formatTimestamp(body.detectedAt);
                    renderMeta(body);
                })
                .catch(function (err) {
                    renderError(err && err.message ? err.message : 'unknown error');
                });
        })();

        // ----------------------------------------------------------------
        // Slice 10: Comfort Budget panel
        // ----------------------------------------------------------------
        (function () {
            var card = document.getElementById('budget-card');
            var hoursEl = document.getElementById('budget-hours');
            var hoursWrap = document.getElementById('budget-hours-wrap');
            var hoursSubEl = document.getElementById('budget-hours-sub');
            var worstLineEl = document.getElementById('budget-worst-line');
            var worstZEl = document.getElementById('budget-worst-z');
            var trendSvg = document.getElementById('budget-trend-svg');
            var trendEmpty = document.getElementById('budget-trend-empty');
            var metaEl = document.getElementById('budget-meta');

            var DOW_LABEL = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
            var SVG_NS = 'http://www.w3.org/2000/svg';

            function colourFromHours(hours, windowDays) {
                // Bands: ≤ 8 = green (one shift), 8–24 = amber, > 24 = red.
                // Scales linearly with window size to keep the bands
                // meaningful when COMFORT_BUDGET_WINDOW_DAYS changes.
                var perDay = windowDays > 0 ? hours / windowDays : 0;
                if (perDay >= 24 / 7) return 'discomfort-high';
                if (perDay >= 8 / 7)  return 'discomfort-medium';
                return 'discomfort-low';
            }

            function renderWorst(worst) {
                if (!worst) {
                    worstLineEl.textContent = '— no day-profile yet';
                    worstZEl.textContent = '';
                    return;
                }
                // textContent-only renders avoid any injection surface.
                while (worstLineEl.firstChild) {
                    worstLineEl.removeChild(worstLineEl.firstChild);
                }
                var label = DOW_LABEL[worst.dayOfWeek] || ('DoW ' + worst.dayOfWeek);
                worstLineEl.appendChild(document.createTextNode(
                    label + ' ' + worst.date + '  '));
                var pill = document.createElement('span');
                pill.className = 'pattern-pill ' + (worst.pattern || 'quiet');
                pill.textContent = worst.pattern || '';
                worstLineEl.appendChild(pill);
                worstZEl.textContent =
                    'mean residual ' + Number(worst.meanResidual).toFixed(2) +
                    ' · |z| max ' + Number(worst.maxAbsZscore).toFixed(2);
            }

            function renderTrend(trend) {
                // Clear previous render.
                while (trendSvg.firstChild) {
                    trendSvg.removeChild(trendSvg.firstChild);
                }
                if (!trend || trend.length === 0) {
                    trendSvg.style.display = 'none';
                    trendEmpty.style.display = 'inline';
                    return;
                }
                trendSvg.style.display = 'block';
                trendEmpty.style.display = 'none';

                // Compute min/max for vertical scaling.
                var means = trend.map(function (p) { return Number(p.meanScore); });
                var lo = Math.min.apply(null, means);
                var hi = Math.max.apply(null, means);
                // Pad so flat series doesn't collapse to a single line.
                if (hi - lo < 1) { hi = lo + 1; }
                var W = 200, H = 60, PAD = 4;
                var nx = trend.length > 1 ? (W - 2 * PAD) / (trend.length - 1) : 0;

                function y(v) {
                    var t = (v - lo) / (hi - lo);
                    return H - PAD - t * (H - 2 * PAD);
                }

                var points = trend.map(function (p, i) {
                    return [PAD + i * nx, y(Number(p.meanScore))];
                });
                var d = points.reduce(function (acc, pt, i) {
                    return acc + (i === 0 ? 'M' : 'L') +
                        pt[0].toFixed(1) + ',' + pt[1].toFixed(1) + ' ';
                }, '');

                var path = document.createElementNS(SVG_NS, 'path');
                path.setAttribute('d', d.trim());
                path.setAttribute('stroke', '#79c0ff');
                path.setAttribute('stroke-width', '2');
                path.setAttribute('fill', 'none');
                trendSvg.appendChild(path);

                // Dot per point + min/max band as thin error bars.
                trend.forEach(function (p, i) {
                    var cx = PAD + i * nx;
                    var hiY = y(Number(p.maxScore));
                    var loY = y(Number(p.minScore));
                    var bar = document.createElementNS(SVG_NS, 'line');
                    bar.setAttribute('x1', cx);
                    bar.setAttribute('x2', cx);
                    bar.setAttribute('y1', hiY);
                    bar.setAttribute('y2', loY);
                    bar.setAttribute('stroke', '#30363d');
                    bar.setAttribute('stroke-width', '1');
                    trendSvg.appendChild(bar);
                    var dot = document.createElementNS(SVG_NS, 'circle');
                    dot.setAttribute('cx', cx);
                    dot.setAttribute('cy', y(Number(p.meanScore)));
                    dot.setAttribute('r', '2.5');
                    dot.setAttribute('fill', '#79c0ff');
                    trendSvg.appendChild(dot);
                });
            }

            function renderMeta(body) {
                var startD = (body.windowStart || '').slice(0, 10);
                var endD = (body.windowEnd || '').slice(0, 10);
                metaEl.textContent =
                    'window ' + startD + ' → ' + endD +
                    ' · threshold ' + body.threshold +
                    ' · source: ComfortScores + DayProfiles';
            }

            function renderError(message) {
                card.classList.add('error');
                hoursEl.textContent = '—';
                worstLineEl.textContent = '—';
                worstZEl.textContent = '';
                trendSvg.style.display = 'none';
                trendEmpty.style.display = 'inline';
                trendEmpty.textContent = 'trend unavailable';
                metaEl.textContent = '/api/comfort/budget: ' + message;
            }

            fetch('/api/comfort/budget', { headers: { 'Accept': 'application/json' } })
                .then(function (resp) {
                    if (!resp.ok) {
                        return resp.json().then(function (body) {
                            throw {
                                status: resp.status,
                                error: body && body.error,
                                message: body && body.message
                            };
                        }, function () {
                            throw {
                                status: resp.status,
                                error: 'http_error',
                                message: 'HTTP ' + resp.status
                            };
                        });
                    }
                    return resp.json();
                })
                .then(function (body) {
                    // body: { hoursOutsideZone, threshold, windowDays,
                    //         windowStart, windowEnd, worstCell, trend }
                    hoursEl.textContent = String(body.hoursOutsideZone);
                    hoursWrap.classList.add(
                        colourFromHours(body.hoursOutsideZone, body.windowDays));
                    hoursSubEl.textContent =
                        'last ' + body.windowDays + ' days, score < ' + body.threshold;
                    renderWorst(body.worstCell);
                    renderTrend(body.trend);
                    renderMeta(body);
                })
                .catch(function (err) {
                    renderError(err && err.message ? err.message : 'unknown error');
                });
        })();

        // ----------------------------------------------------------------
        // Slice 1: SSE heartbeat (kept as smoke test for slice-1 plumbing)
        // ----------------------------------------------------------------
        (function () {
            var counter = document.getElementById('tick-count');
            var lastTick = document.getElementById('last-tick-ts');
            var connState = document.getElementById('conn-state');
            var ticks = 0;

            var es = new EventSource('/api/alerts/stream');

            es.addEventListener('open', function () {
                connState.textContent = 'connected';
            });

            es.addEventListener('server-tick', function (ev) {
                ticks += 1;
                counter.textContent = ticks.toString();
                try {
                    var payload = JSON.parse(ev.data);
                    lastTick.textContent = 'last tick: ' + payload.ts +
                        ' (event id ' + ev.lastEventId + ')';
                } catch (e) {
                    lastTick.textContent = 'last tick: (unparseable payload)';
                }
            });

            es.addEventListener('error', function () {
                connState.textContent = 'reconnecting…';
            });

            window.addEventListener('beforeunload', function () {
                try { es.close(); } catch (e) { /* ignore */ }
            });
        })();
    </script>
</body>
</html>
