@page
@model ClimaSense.Web.Pages.IndexModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClimaSense — dashboard</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
            background: #0d1117;
            color: #c9d1d9;
            margin: 0;
            padding: 2rem;
            line-height: 1.5;
        }
        h1 {
            color: #58a6ff;
            font-weight: 500;
            margin-top: 0;
        }
        code, pre {
            background: #161b22;
            border-radius: 6px;
            padding: 0.15rem 0.4rem;
            color: #d2a8ff;
        }
        pre {
            padding: 1rem;
            overflow-x: auto;
        }
        .panel {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 8px;
            padding: 1rem 1.25rem;
            margin: 1rem 0;
        }
        /* Slice 3: latest-reading card */
        .latest-card {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            align-items: center;
            background: linear-gradient(145deg, #161b22, #0d1117);
            border: 1px solid #30363d;
            border-radius: 12px;
            padding: 1.5rem 2rem;
            margin: 1rem 0 2rem 0;
        }
        .latest-card .reading {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
        }
        .latest-card .label {
            color: #8b949e;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }
        .latest-card .value {
            font-size: 3rem;
            font-weight: 600;
            color: #f0f6fc;
            line-height: 1;
        }
        .latest-card .value .unit {
            font-size: 1.5rem;
            font-weight: 400;
            color: #8b949e;
            margin-left: 0.25rem;
        }
        .latest-card .meta {
            grid-column: 1 / -1;
            color: #8b949e;
            font-size: 0.85rem;
            border-top: 1px solid #30363d;
            padding-top: 0.75rem;
        }
        .latest-card.error .value {
            color: #f85149;
            font-size: 1.5rem;
            font-weight: 500;
        }
        .heartbeat-counter {
            font-size: 2rem;
            font-weight: 600;
            color: #56d364;
        }
        .heartbeat-meta {
            color: #8b949e;
            font-size: 0.9rem;
        }
        ul.legend {
            color: #8b949e;
            font-size: 0.9rem;
        }
        /* Slice 7: comfort card */
        .comfort-card {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 1.5rem;
            align-items: center;
            background: linear-gradient(145deg, #161b22, #0d1117);
            border: 1px solid #30363d;
            border-radius: 12px;
            padding: 1.25rem 1.75rem;
            margin: 1rem 0 2rem 0;
        }
        .comfort-card .field {
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
        }
        .comfort-card .label {
            color: #8b949e;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }
        .comfort-card .value {
            font-size: 2.25rem;
            font-weight: 600;
            color: #f0f6fc;
            line-height: 1;
        }
        .comfort-card .value .unit {
            font-size: 1.25rem;
            font-weight: 400;
            color: #8b949e;
            margin-left: 0.25rem;
        }
        .comfort-card .meta {
            grid-column: 1 / -1;
            color: #8b949e;
            font-size: 0.85rem;
            border-top: 1px solid #30363d;
            padding-top: 0.75rem;
        }
        .comfort-card.error .value {
            color: #f85149;
            font-size: 1.25rem;
            font-weight: 500;
        }
        .rating-excellent { color: #56d364; }
        .rating-acceptable { color: #79c0ff; }
        .rating-marginal { color: #d29922; }
        .rating-uncomfortable { color: #f85149; }
    </style>
</head>
<body>
    <h1>ClimaSense — dashboard</h1>

    <nav style="color:#8b949e;font-size:0.9rem;margin-bottom:0.5rem;">
        Dashboard ·
        <a href="/Explorer" style="color:#58a6ff;">Historical Explorer</a> ·
        <a href="/Analysis" style="color:#58a6ff;">Model Leaderboard</a>
    </nav>

    <p>
        Live read: the latest <code>SensorReadings</code> row served by
        the .NET tier directly from SQL (no ml-tier hop). The
        heartbeat counter below remains as the SSE plumbing smoke test
        from slice 1; later slices replace this whole page with the
        proper dashboard. Slice 4 adds the
        <a href="/Explorer" style="color:#58a6ff;">Historical Explorer</a>
        for range + heatmap exploration.
    </p>

    <!-- ============================================== -->
    <!-- Slice 3: latest-reading card                  -->
    <!-- ============================================== -->
    <section class="latest-card" id="latest-card">
        <div class="reading">
            <span class="label">Temperature</span>
            <span class="value">
                <span id="latest-temp">&hellip;</span><span class="unit">&deg;C</span>
            </span>
        </div>
        <div class="reading">
            <span class="label">Humidity</span>
            <span class="value">
                <span id="latest-humidity">&hellip;</span><span class="unit">%</span>
            </span>
        </div>
        <div class="meta" id="latest-meta">
            Fetching latest reading from
            <code>/api/readings/latest</code>&hellip;
        </div>
    </section>

    <!-- ============================================== -->
    <!-- Slice 7: comfort score card                   -->
    <!-- ============================================== -->
    <section class="comfort-card" id="comfort-card">
        <div class="field">
            <span class="label">Comfort score</span>
            <span class="value">
                <span id="comfort-score">&hellip;</span><span class="unit">/100</span>
            </span>
        </div>
        <div class="field">
            <span class="label">Rating</span>
            <span class="value" id="comfort-rating-wrap">
                <span id="comfort-rating">&hellip;</span>
            </span>
        </div>
        <div class="field">
            <span class="label">Season</span>
            <span class="value">
                <span id="comfort-season">&hellip;</span>
            </span>
        </div>
        <div class="meta" id="comfort-meta">
            Fetching latest comfort score from
            <code>/api/comfort/current</code>&hellip;
        </div>
    </section>

    <section class="panel">
        <strong>Heartbeat (slice-1 SSE smoke test)</strong>
        <div class="heartbeat-counter" id="tick-count">0</div>
        <div class="heartbeat-meta">
            <span id="last-tick-ts">awaiting first heartbeat&hellip;</span>
            &nbsp;|&nbsp;
            <span id="conn-state">connecting&hellip;</span>
        </div>
    </section>

    <section class="panel">
        <strong>What slice 7 ships</strong>
        <ul class="legend">
            <li>Pure <code>ComfortCalculator</code> on the ml tier —
                ASHRAE 55-2020 graphical comfort zone with summer /
                winter polygons (per ADR-0005). Season is selected by
                calendar month + <code>COMFORT_HEMISPHERE</code> env
                var (default <code>N</code>).</li>
            <li>APScheduler β-prime gate (slice-5 pattern) — one
                <code>ComfortScores</code> row per replay-hour.</li>
            <li><code>GET /api/comfort/current</code> served by the
                .NET tier directly from
                <code>dbo.fv_comfortscores_at_cursor(@@asOf)</code>
                (read-path bypass per ADR-0010).</li>
            <li><code>POST /api/ml/run/comfort</code> proxies the
                .NET tier through to the ml-tier
                <code>GET /api/comfort/score?hours=24</code> for
                on-demand recompute (idempotent on the cursor's
                bucket).</li>
        </ul>
    </section>

    <script>
        // ----------------------------------------------------------------
        // Slice 3: latest reading
        // ----------------------------------------------------------------
        (function () {
            var tempEl = document.getElementById('latest-temp');
            var humidityEl = document.getElementById('latest-humidity');
            var metaEl = document.getElementById('latest-meta');
            var cardEl = document.getElementById('latest-card');

            function formatTimestamp(iso) {
                try {
                    var d = new Date(iso);
                    return d.toLocaleString(undefined, {
                        year: 'numeric', month: 'short', day: '2-digit',
                        hour: '2-digit', minute: '2-digit',
                        timeZoneName: 'short',
                    });
                } catch (e) {
                    return iso;
                }
            }

            // textContent-only meta rendering. Avoids innerHTML so the
            // server-supplied readingTime can never inject markup even
            // if a future change starts shipping it from the wire as
            // a string we don't trust.
            function renderMeta(body) {
                while (metaEl.firstChild) {
                    metaEl.removeChild(metaEl.firstChild);
                }
                metaEl.appendChild(document.createTextNode('as of '));
                var ts = document.createElement('strong');
                ts.textContent = formatTimestamp(body.readingTime);
                metaEl.appendChild(ts);
                metaEl.appendChild(document.createTextNode(' · source: '));
                var code = document.createElement('code');
                code.textContent = 'SensorReadings';
                metaEl.appendChild(code);
                metaEl.appendChild(document.createTextNode(
                    ' (row with largest ReadingTime ≤ cursor)'));
            }

            function renderError(message) {
                cardEl.classList.add('error');
                // Replace temperature / humidity values with em-dashes.
                var tempParent = tempEl.parentElement;
                while (tempParent.firstChild) {
                    tempParent.removeChild(tempParent.firstChild);
                }
                tempParent.textContent = '—';
                var humParent = humidityEl.parentElement;
                while (humParent.firstChild) {
                    humParent.removeChild(humParent.firstChild);
                }
                humParent.textContent = '—';
                metaEl.textContent =
                    '/api/readings/latest failed: ' + message;
            }

            fetch('/api/readings/latest', { headers: { 'Accept': 'application/json' } })
                .then(function (resp) {
                    if (!resp.ok) {
                        return resp.json().then(function (body) {
                            throw {
                                status: resp.status,
                                error: body && body.error,
                                message: body && body.message
                            };
                        }, function () {
                            throw {
                                status: resp.status,
                                error: 'http_error',
                                message: 'HTTP ' + resp.status
                            };
                        });
                    }
                    return resp.json();
                })
                .then(function (body) {
                    tempEl.textContent = (body.temperatureC).toFixed(1);
                    humidityEl.textContent = (body.humidityPct).toFixed(1);
                    renderMeta(body);
                })
                .catch(function (err) {
                    renderError(err && err.message ? err.message : 'unknown error');
                });
        })();

        // ----------------------------------------------------------------
        // Slice 7: comfort score
        // ----------------------------------------------------------------
        (function () {
            var scoreEl = document.getElementById('comfort-score');
            var ratingEl = document.getElementById('comfort-rating');
            var ratingWrap = document.getElementById('comfort-rating-wrap');
            var seasonEl = document.getElementById('comfort-season');
            var metaEl = document.getElementById('comfort-meta');
            var cardEl = document.getElementById('comfort-card');

            function capitalize(s) {
                if (typeof s !== 'string' || s.length === 0) return s;
                return s.charAt(0).toUpperCase() + s.slice(1);
            }

            function formatTimestamp(iso) {
                try {
                    var d = new Date(iso);
                    return d.toLocaleString(undefined, {
                        year: 'numeric', month: 'short', day: '2-digit',
                        hour: '2-digit', minute: '2-digit',
                        timeZoneName: 'short',
                    });
                } catch (e) {
                    return iso;
                }
            }

            function renderMeta(body) {
                while (metaEl.firstChild) {
                    metaEl.removeChild(metaEl.firstChild);
                }
                metaEl.appendChild(document.createTextNode('bucket '));
                var ts = document.createElement('strong');
                ts.textContent = formatTimestamp(body.bucketTime);
                metaEl.appendChild(ts);
                metaEl.appendChild(document.createTextNode(' · source: '));
                var code = document.createElement('code');
                code.textContent = 'ComfortScores';
                metaEl.appendChild(code);
                metaEl.appendChild(document.createTextNode(
                    ' (latest row, cursor-clipped)'));
            }

            function renderError(message) {
                cardEl.classList.add('error');
                scoreEl.parentElement.textContent = '—';
                ratingEl.textContent = '—';
                seasonEl.textContent = '—';
                metaEl.textContent =
                    '/api/comfort/current: ' + message;
            }

            fetch('/api/comfort/current', { headers: { 'Accept': 'application/json' } })
                .then(function (resp) {
                    if (resp.status === 404) {
                        return resp.json().then(function (body) {
                            throw {
                                status: 404,
                                error: body && body.error,
                                message: (body && body.message) ||
                                    'no comfort row yet',
                            };
                        }, function () {
                            throw { status: 404, error: 'no_comfort_yet',
                                message: 'no comfort row yet' };
                        });
                    }
                    if (!resp.ok) {
                        return resp.json().then(function (body) {
                            throw {
                                status: resp.status,
                                error: body && body.error,
                                message: body && body.message
                            };
                        }, function () {
                            throw {
                                status: resp.status,
                                error: 'http_error',
                                message: 'HTTP ' + resp.status
                            };
                        });
                    }
                    return resp.json();
                })
                .then(function (body) {
                    // body: { score, rating, season, bucketTime, computedAt }
                    scoreEl.textContent = (body.score).toFixed(0);
                    ratingEl.textContent = capitalize(body.rating);
                    seasonEl.textContent = capitalize(body.season);
                    // Colour the rating wrapper by rating band.
                    ratingWrap.classList.add('rating-' + body.rating);
                    renderMeta(body);
                })
                .catch(function (err) {
                    renderError(err && err.message ? err.message : 'unknown error');
                });
        })();

        // ----------------------------------------------------------------
        // Slice 1: SSE heartbeat (kept as smoke test for slice-1 plumbing)
        // ----------------------------------------------------------------
        (function () {
            var counter = document.getElementById('tick-count');
            var lastTick = document.getElementById('last-tick-ts');
            var connState = document.getElementById('conn-state');
            var ticks = 0;

            var es = new EventSource('/api/alerts/stream');

            es.addEventListener('open', function () {
                connState.textContent = 'connected';
            });

            es.addEventListener('server-tick', function (ev) {
                ticks += 1;
                counter.textContent = ticks.toString();
                try {
                    var payload = JSON.parse(ev.data);
                    lastTick.textContent = 'last tick: ' + payload.ts +
                        ' (event id ' + ev.lastEventId + ')';
                } catch (e) {
                    lastTick.textContent = 'last tick: (unparseable payload)';
                }
            });

            es.addEventListener('error', function () {
                connState.textContent = 'reconnecting…';
            });

            window.addEventListener('beforeunload', function () {
                try { es.close(); } catch (e) { /* ignore */ }
            });
        })();
    </script>
</body>
</html>
