# syntax=docker/dockerfile:1.7
#
# ClimaSense.ML — FastAPI tier (slice 3: bcp bootstrap + stubs).
#
# We use the official `uv` image so the Python toolchain matches local
# dev. `unixodbc` + the Microsoft ODBC Driver 18 for SQL Server are
# installed so pyodbc can talk to the `db` service.
#
# Slice 3 changes (on top of slice 2's contract / codegen):
#   * `mssql-tools18` is installed alongside `msodbcsql18`. The package
#     ships the `bcp` binary at `/opt/mssql-tools18/bin/bcp`. It is used
#     ONCE per cold start by `IngestionService.bootstrap_from_csv_if_empty`
#     to bulk-load `/tmp/seed.csv` into `dbo.SensorReadings`. After the
#     load completes the binary is unused for the lifetime of the
#     process.
#   * `pandas` joins the runtime deps — the transform that produces
#     `/tmp/seed.csv` lives in `climasense_ml.ingestion`.
#
# Slice 2 changes (carried forward):
#   * `datamodel-code-generator` runs at image-build time to regenerate
#     `schemas/generated.py` from the bundled `contracts/openapi.yaml`.
#     The regen is idempotent — rerunning a clean build produces zero
#     diff against the committed file.
#   * The contract YAML is copied to `/app/contracts/openapi.yaml`
#     inside the image so `ContractValidator` can load it at startup.

ARG PYTHON_VERSION=3.13

FROM ghcr.io/astral-sh/uv:python${PYTHON_VERSION}-bookworm-slim AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/opt/venv

# Microsoft ODBC Driver 18 for SQL Server + mssql-tools18 (for `bcp`).
#
# `mssql-tools18` provides `bcp` and `sqlcmd` at /opt/mssql-tools18/bin/.
# Slice 3's bootstrap (`IngestionService.bootstrap_from_csv_if_empty`)
# shells out to `bcp` exactly once per cold start. The binary is not
# used at runtime after the bulk load completes.
#
# ACCEPT_EULA=Y is required during the install layer; the EULA terms
# are the standard Microsoft ODBC / mssql-tools licence carried over
# from the slice-1 ODBC install.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        curl ca-certificates gnupg apt-transport-https \
    && curl -fsSL https://packages.microsoft.com/keys/microsoft.asc \
        | gpg --dearmor -o /usr/share/keyrings/microsoft-prod.gpg \
    && echo "deb [arch=amd64,arm64 signed-by=/usr/share/keyrings/microsoft-prod.gpg] https://packages.microsoft.com/debian/12/prod bookworm main" \
        > /etc/apt/sources.list.d/mssql-release.list \
    && apt-get update \
    && ACCEPT_EULA=Y apt-get install -y --no-install-recommends \
        msodbcsql18 mssql-tools18 unixodbc unixodbc-dev \
    && rm -rf /var/lib/apt/lists/*

# Surface bcp / sqlcmd on PATH so the bootstrap's `subprocess.run`
# can resolve them by name even when callers don't use the absolute
# /opt path.
ENV PATH="/opt/mssql-tools18/bin:$PATH"

WORKDIR /app

# Install runtime dependencies first so they cache independently of
# source changes. Slice 2 adds `PyYAML` (ContractValidator) and
# `datamodel-code-generator` (regen at build time).
COPY src/ClimaSense.ML/pyproject.toml ./
RUN uv venv /opt/venv \
    && uv pip install --python /opt/venv/bin/python --no-cache \
        "fastapi>=0.115,<0.120" \
        "uvicorn[standard]>=0.32,<0.40" \
        "python-json-logger>=2.0.7,<3" \
        "sqlalchemy>=2.0.36,<3" \
        "pyodbc>=5.2,<6" \
        "pydantic>=2.9,<3" \
        "PyYAML>=6.0,<7" \
        "pandas>=2.2,<4" \
        "datamodel-code-generator>=0.26,<1"

# Contract first — codegen reads from /app/contracts/openapi.yaml.
COPY contracts ./contracts

# Application source.
COPY src/ClimaSense.ML/climasense_ml ./climasense_ml

# Regenerate the Pydantic models from the bundled contract. The output
# of `datamodel-code-generator` is deterministic given fixed input +
# fixed flags, so this step's effect on the image is a no-op when the
# committed `schemas/generated.py` is already up-to-date.
#
# We prepend the same banner the regen script emits so the in-image
# file matches what a developer running `scripts/regen-contracts.sh`
# would produce.
RUN /opt/venv/bin/python -m datamodel_code_generator \
        --input /app/contracts/openapi.yaml \
        --input-file-type openapi \
        --output /app/climasense_ml/schemas/generated.py \
        --output-model-type pydantic_v2.BaseModel \
        --use-schema-description \
        --use-double-quotes \
        --snake-case-field \
        --field-constraints \
        --target-python-version 3.13 \
        --disable-timestamp \
        --use-standard-collections \
        --use-union-operator \
        --enable-version-header \
    && /opt/venv/bin/python - <<'PYEOF'
import pathlib
p = pathlib.Path("/app/climasense_ml/schemas/generated.py")
body = p.read_text()
banner = (
    "# === GENERATED — DO NOT EDIT BY HAND ===\n"
    "# Regenerated by scripts/regen-contracts.sh from contracts/openapi.yaml.\n"
    "# Pydantic v2 models. camelCase JSON aliases on the wire are produced\n"
    "# by datamodel-code-generator's `--snake-case-field` mode plus the\n"
    "# emitted `Field(..., alias=\"camelCase\")` annotations.\n"
    "\n"
)
if not body.startswith("# === GENERATED"):
    p.write_text(banner + body)
PYEOF

ENV PATH="/opt/venv/bin:$PATH"
EXPOSE 8000

# Lifespan runs `ContractValidator` immediately on startup — the
# process exits non-zero on any divergence between FastAPI's emitted
# spec and `/app/contracts/openapi.yaml`.
CMD ["uvicorn", "climasense_ml.main:app", "--host", "0.0.0.0", "--port", "8000"]
