# ClimaSense — example environment file.
#
# Copy this file to `.env` (gitignored) before running `docker compose up`.
# Real secrets must NEVER be committed.
#
# Slice 1 (Foundation) only consumes `MSSQL_SA_PASSWORD` and the cross-tier
# logging variables; later slices will add upstream-DB and clock-mode vars.

# --- SQL Server (bundled — runs ON util02 alongside the existing server) ---
# util02 runs ClimaSense's OWN SQL Server (the `db` service), enabled by the
# `bundled-db` profile below. The existing MSSQL on util02 is left untouched:
# the bundled db publishes no host port (no 1433), so there is zero conflict.
# MSSQL_SA_PASSWORD sets THIS bundled db's SA password on first boot, and
# web / ml / db-init reach it over the compose network as host `db`.
COMPOSE_PROFILES=bundled-db
MSSQL_SA_PASSWORD=321!Ende
CLIMASENSE_DB_HOST=db
CLIMASENSE_DB_PORT=1433

# --- ClimaSense's own DB ---
# Database name created by `init-db.sql`.
CLIMASENSE_DB_NAME=ClimaSense

# --- Web tier host publication (util02 deploy) ---
# Host interface + port the `web` container's 8080 is published on, consumed
# by compose as `${WEB_BIND_HOST:-127.0.0.1}:${WEB_PUBLISH_PORT:-8080}`.
# 0.0.0.0:18080 publishes the dashboard on the lab LAN at http://util02:18080
# (8080 and 8090 are both in use on util02; 18080 was free in a port scan —
# change it if it collides). db (1433) and ml (8000) are never published.
# No app auth — keep util02 trusted.
WEB_BIND_HOST=0.0.0.0
WEB_PUBLISH_PORT=18080

# --- Cross-tier logging ---
# Default service log level. JSON stdout always carries `request_id`,
# `service`, `level`, `ts`, `msg`.
LOG_LEVEL=Information
PYTHON_LOG_LEVEL=INFO

# --- Slice 12 placeholders (NOT consumed in slice 1) ---
# Mode for `IClock`: `replay` (cursor) or `wall` (DateTime.UtcNow).
# Slice 1 only ships `WallClock`; this var is read but the value is ignored.
CLIMASENSE_CLOCK_MODE=wall
# Default replay speed multiplier (slice 12).
REPLAY_SPEED_MULTIPLIER=60
# Hemisphere for ASHRAE season selection (slice 8).
COMFORT_HEMISPHERE=N
